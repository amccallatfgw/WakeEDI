# ── Azure SQL (app user — no DDL rights) ─────────────────────
MSSQL_HOST=sql-waketech-prod.database.windows.net
MSSQL_USER=fw_app
MSSQL_PASS=
MSSQL_DB=Wake-edi

# ── Azure SQL (deploy user — DDL rights for migrations) ──────
MSSQL_DEPLOY_USER=fw_deploy
MSSQL_DEPLOY_PASS=

# ── Target Databases (cross-app writes via SARA) ─────────────
FREIGHTWAKE_DB=waketech_freightwake
WAKESIGNAL_DB=waketech_wakesignal
WAKEMAIL_DB=waketech_wakemail

# ── Auth ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── SMTP (email) ─────────────────────────────────────────────
SMTP_HOST=mail.waketech.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WakeEDI <noreply@waketech.com>

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://edi.waketech.ai
INTERNAL_API_KEY=

# ── Optional ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
